---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Post {
    url: string;
    frontmatter: {
        pageTitle: string;
        description?: string;
        date?: string;
    };
}

// 1. We ask Vite to fetch the modules using import.meta.glob
// The `{ eager: true }` tells it to read the files immediately.
const postsObject = import.meta.glob("./posts/*.md", { eager: true });

// 2. The glob gives us an "Object", but we want an "Array" so we can map() over it.
const allPosts = Object.values(postsObject) as Post[];
---

<BaseLayout pageTitle="My Blog Archives">
    <div class="blog-header">
        <h1>Journeys & Insights</h1>
        <p>
            Documenting my learning, thoughts, and technical discoveries in
            Astro.
        </p>
    </div>

    <ul class="post-grid">
        {
            allPosts.map((post) => (
                <li class="post-card">
                    {post.frontmatter.date && (
                        <span class="post-date">
                            {new Date(post.frontmatter.date).toLocaleDateString(
                                "en-US",
                                {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                }
                            )}
                        </span>
                    )}
                    <h2 class="post-title">
                        <a href={post.url}>{post.frontmatter.pageTitle}</a>
                    </h2>
                    {post.frontmatter.description && (
                        <p class="post-description">
                            {post.frontmatter.description}
                        </p>
                    )}
                    <span class="read-more">
                        Read Article
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <line x1="5" y1="12" x2="19" y2="12" />
                            <polyline points="12 5 19 12 12 19" />
                        </svg>
                    </span>
                </li>
            ))
        }
    </ul>
</BaseLayout>

<style>
    .blog-header {
        text-align: center;
        margin-bottom: 4rem;
        animation: fade-down 0.8s ease-out forwards;
    }

    .blog-header h1 {
        font-size: 3.5rem;
        color: var(--text-main);
        font-weight: 700;
        letter-spacing: -1px;
        margin-bottom: 1rem;
        margin-top: 0;
    }

    .blog-header p {
        color: var(--text-muted);
        font-size: 1.15rem;
        max-width: 500px;
        margin: 0 auto;
    }

    .post-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .post-card {
        background: #ffffff;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        padding: 2rem;
        transition: all 0.2s ease-in-out;
        position: relative;
        display: flex;
        flex-direction: column;
        animation: fade-up 0.8s ease-out forwards;
        opacity: 0;
    }

    .post-card:nth-child(1) {
        animation-delay: 0.1s;
    }
    .post-card:nth-child(2) {
        animation-delay: 0.2s;
    }
    .post-card:nth-child(3) {
        animation-delay: 0.3s;
    }

    .post-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05),
            0 4px 6px -2px rgba(0, 0, 0, 0.025);
        border-color: #d4d4d4;
        background: #ffffff;
    }

    .post-date {
        font-size: 0.85rem;
        color: var(--text-muted);
        font-weight: 500;
        margin-bottom: 0.75rem;
        display: block;
    }

    .post-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-main);
        margin: 0 0 1rem 0;
        line-height: 1.3;
    }

    .post-title a {
        color: inherit;
        text-decoration: none;
    }

    .post-title a::after {
        content: "";
        position: absolute;
        inset: 0;
    }

    .post-title a:hover {
        text-decoration: none;
    }

    .post-description {
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 2rem;
        flex-grow: 1;
    }

    .read-more {
        display: inline-flex;
        align-items: center;
        font-weight: 600;
        color: var(--text-main);
        font-size: 0.9rem;
        margin-top: auto;
        transition: color 0.3s ease;
    }

    .post-card:hover .read-more {
        color: var(--accent);
    }

    .read-more svg {
        width: 16px;
        height: 16px;
        margin-left: 8px;
        transition: transform 0.3s ease;
    }

    .post-card:hover .read-more svg {
        transform: translateX(6px);
    }

    @keyframes fade-up {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fade-down {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
