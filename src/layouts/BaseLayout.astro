---
const { pageTitle } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{pageTitle}</title>

        <!-- 1. Let's grab a beautiful modern font called 'Outfit' -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap"
            rel="stylesheet"
        />

        <style>
            /* 2. CSS Variables for a bright, professional, feel-good light mode */
            :root {
                --bg-color: #fafafa; /* Soft off-white */
                --text-main: #171717; /* Crisp dark gray */
                --text-muted: #737373; /* Professional medium gray */
                --accent: #2563eb; /* Optimistic, trusted blue */
                --accent-glow: rgba(
                    37,
                    99,
                    235,
                    0.08
                ); /* Soft background glow */
            }

            body {
                font-family: "Outfit", sans-serif;
                line-height: 1.7;
                margin: 0;
                background-color: var(--bg-color);
                color: var(--text-main);

                /* Subtle radial glow effect at the top of the page */
                background-image: radial-gradient(
                    circle at 50% 0%,
                    var(--accent-glow) 0%,
                    transparent 50%
                );
                background-repeat: no-repeat;
            }

            .wrapper {
                max-width: 700px;
                margin: 0 auto;
                padding: 2rem 1.5rem;
            }

            /* 3. Glassmorphism Navigation Bar  */
            header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 4rem;
                padding: 1.5rem 2rem;
                background: rgba(255, 255, 255, 0.7); /* Transparent white */
                backdrop-filter: blur(12px); /* Blurs whatever is behind it */
                border: 1px solid rgba(0, 0, 0, 0.05); /* Faint dark border */
                border-radius: 16px;
                box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
            }

            .logo {
                font-size: 1.5rem;
                font-weight: 700;
                color: var(--text-main);
                text-decoration: none;
                letter-spacing: -0.5px;
            }

            nav a {
                margin-left: 2rem;
                text-decoration: none;
                color: var(--text-muted);
                font-weight: 600;
                transition: color 0.3s ease;
                position: relative;
            }

            nav a:hover {
                color: var(--text-main);
            }

            /* 4. Micro-animation: A line that sweeps in under links when hovered */
            nav a::after {
                content: "";
                position: absolute;
                width: 0%;
                height: 2px;
                bottom: -4px;
                left: 0;
                background-color: var(--accent);
                transition: width 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            }

            nav a:hover::after {
                width: 100%;
            }

            /* Smooth entry animation when you open a page */
            main {
                animation: fade-in 0.8s ease-out;
            }

            @keyframes fade-in {
                from {
                    opacity: 0;
                    transform: translateY(15px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* Better typography spacing */
            h1,
            h2,
            h3 {
                letter-spacing: -0.5px;
                line-height: 1.2;
                margin-top: 2rem;
            }

            /* Make standard links pop */
            a {
                color: var(--accent);
                text-decoration: none;
            }
            a:hover {
                text-decoration: underline;
            }
        </style>
    </head>
    <body>
        <div class="wrapper">
            <header>
                <a href="/" class="logo">AstroBlog.</a>
                <nav>
                    <!-- I removed 'About' and just left Home and Blog -->
                    <a href="/">Home</a>
                    <a href="/blog">Blog</a>
                </nav>
            </header>

            <main>
                <slot />
            </main>
        </div>
    </body>
</html>
